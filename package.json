    "crawl": "node ingestion/scripts/catalogue-crawler.js",
    "crawl:no-extract": "node ingestion/scripts/catalogue-crawler.js --no-extract",
    "pipeline": "node ingestion/scripts/pipeline.js",
    "pipeline:no-crawl": "node ingestion/scripts/pipeline.js --no-crawl",
    "pipeline:dry-run": "node ingestion/scripts/pipeline.js --dry-run"
