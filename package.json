    "ingest:pilot:maford-reamer-272-v1": "node ingestion/scripts/pilot-maford-reamer-272-v1.js",
    "ingest:pilot:maford-reamer-272-v2-verify": "node ingestion/scripts/pilot-maford-reamer-272-v2-verify.js",
    "ingest:pilot:maford-reamer-272-boundary": "node ingestion/scripts/pilot-maford-reamer-272-boundary.js",
    "ingest:maford-reamer-272-full-range": "node ingestion/scripts/extract-maford-reamer-272-full-range.js",
    "ingest:maford-272-normalization-review": "node ingestion/scripts/create-maford-272-normalization-review.js",
    "ingest:maford-272-validation-sample": "node ingestion/scripts/create-maford-272-validation-sample.js",
