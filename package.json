{
  "scripts": {
    "build": "npm run build:css && npm run build:directory",
    "build:css": "tailwindcss -i ./src/tailwind.css -o ./assets/tailwind.css --minify",
    "build:directory": "esbuild ./directory-app.jsx --bundle --minify --define:process.env.NODE_ENV=\\\"production\\\" --outfile=./assets/directory-app.js",
