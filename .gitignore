# Local Netlify folder
.netlify

# Node
node_modules/

# Python envs
.venv/
.venv2/
venv/
__pycache__/

# OS
.DS_Store

# Claude Code local config — ignore personal/local files, track shared commands
.claude/settings.local.json
.claude/launch.json

# Local backups
*-fixed.html
*.bak
*.backup
*.backup-*
.env

# Test & scratch artifacts (ephemeral local outputs)
daily-agents-worker/test-*.html

# PDF catalogs — large binary files, processed locally only
*.pdf
# Exception: inbox PDFs can be committed to trigger the CI ingestion pipeline.
# GitHub hard limit is 100 MB per file. Use workflow_dispatch for larger PDFs.
!ingestion/inbox/*.pdf
# Exception: failed PDFs committed for audit and retry (error.txt alongside them)
!ingestion/failed/*.pdf
!ingestion/failed/*.txt
ingestion/input/
ingestion/output/processed/
# ingestion/output/claude-extracted/ is force-added by the CI workflow so staging
# review.json files are committed and visible in the human review UI.

# Large text dumps from PDF extraction
*.txt

# Temp / personal notes
*.rtf
*sohbet*

# Nested repo copies / legacy folders
ToolAdvisor/
.codex/

# Staging data files
directory-data-staging.js
data/
